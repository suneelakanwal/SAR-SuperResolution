class SARDataset(Dataset):
    def __init__(self, h5_path):
        with h5py.File(h5_path, 'r') as hf:
            self.length = len(hf['data'])
        self.h5_path = h5_path
        self.hf      = None

    def __len__(self):
        return self.length

    def __getitem__(self, idx):
        if self.hf is None:
            self.hf = h5py.File(self.h5_path, 'r')
        # HR = full 66×66
        hr = torch.from_numpy(self.hf['label'][idx])   # (1, 66, 66)

        # LR = downsample back to 33×33 so Generator can upscale ×2 → 66×66
        hr_pil = transforms.ToPILImage()(hr)
        lr_pil = hr_pil.resize((33, 33), Image.BICUBIC)
        lr     = transforms.ToTensor()(lr_pil)          # (1, 33, 33)

        return lr, hr


