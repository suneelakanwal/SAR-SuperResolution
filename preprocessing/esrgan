# ── Residual Dense Block (RDB) ───────────────────────────────
class ResidualDenseBlock(nn.Module):
    """
    Residual Dense Block — core unit of RRDB.
    5 conv layers with dense connections + residual scaling.
    """
    def __init__(self, nf=64, gc=32, bias=True):
        super().__init__()
        self.conv1 = nn.Conv2d(nf,      gc, 3, 1, 1, bias=bias)
        self.conv2 = nn.Conv2d(nf+gc,   gc, 3, 1, 1, bias=bias)
        self.conv3 = nn.Conv2d(nf+2*gc, gc, 3, 1, 1, bias=bias)
        self.conv4 = nn.Conv2d(nf+3*gc, gc, 3, 1, 1, bias=bias)
        self.conv5 = nn.Conv2d(nf+4*gc, nf, 3, 1, 1, bias=bias)
        self.lrelu = nn.LeakyReLU(negative_slope=0.2, inplace=True)
 
    def forward(self, x):
        x1 = self.lrelu(self.conv1(x))
        x2 = self.lrelu(self.conv2(torch.cat([x, x1], dim=1)))
        x3 = self.lrelu(self.conv3(torch.cat([x, x1, x2], dim=1)))
        x4 = self.lrelu(self.conv4(torch.cat([x, x1, x2, x3], dim=1)))
        x5 = self.conv5(torch.cat([x, x1, x2, x3, x4], dim=1))
        return x5 * 0.2 + x   # residual scaling β=0.2
 
 
# ── Residual-in-Residual Dense Block (RRDB) ──────────────────
class RRDB(nn.Module):
    """RRDB: 3 stacked RDBs with outer residual connection."""
    def __init__(self, nf=64, gc=32):
        super().__init__()
        self.rdb1 = ResidualDenseBlock(nf, gc)
        self.rdb2 = ResidualDenseBlock(nf, gc)
        self.rdb3 = ResidualDenseBlock(nf, gc)
 
    def forward(self, x):
        out = self.rdb1(x)
        out = self.rdb2(out)
        out = self.rdb3(out)
        return out * 0.2 + x
 
 
# ── Generator (RRDBNet) ───────────────────────────────────────
class RRDBNet(nn.Module):
    """
    ESRGAN Generator — RRDBNet.
    in_nc=1  : single-channel grayscale SAR input
    out_nc=1 : single-channel output
    nf=64    : feature channels (reduced from 128 for Kaggle RAM)
    nb=8     : number of RRDB blocks (reduced from 23)
    scale=2  : upscale factor
    """
    def __init__(self, in_nc=1, out_nc=1, nf=64, nb=8, scale=2):
        super().__init__()
        self.scale = scale
 
        # First conv
        self.conv_first = nn.Conv2d(in_nc, nf, 3, 1, 1, bias=True)
 
        # RRDB trunk
        trunk = [RRDB(nf) for _ in range(nb)]
        self.trunk   = nn.Sequential(*trunk)
        self.conv_trunk = nn.Conv2d(nf, nf, 3, 1, 1, bias=True)
 
        # Upsampling (pixel shuffle)
        n_upscale = int(np.log2(scale))
        upsample_layers = []
        for _ in range(n_upscale):
            upsample_layers += [
                nn.Conv2d(nf, nf * 4, 3, 1, 1, bias=True),
                nn.PixelShuffle(2),
                nn.LeakyReLU(0.2, inplace=True),
            ]
        self.upsample = nn.Sequential(*upsample_layers)
 
        self.conv_hr   = nn.Conv2d(nf, nf, 3, 1, 1, bias=True)
        self.conv_last = nn.Conv2d(nf, out_nc, 3, 1, 1, bias=True)
        self.lrelu     = nn.LeakyReLU(negative_slope=0.2, inplace=True)
 
    def forward(self, x):
        fea    = self.conv_first(x)
        trunk  = self.conv_trunk(self.trunk(fea))
        fea    = fea + trunk                        # global residual
        fea    = self.upsample(fea)
        out    = self.conv_last(self.lrelu(self.conv_hr(fea)))
        return out
 
 
# ── Discriminator ─────────────────────────────────────────────
class Discriminator(nn.Module):
    """
    VGG-style discriminator for 66×66 single-channel patches.
    """
    def __init__(self, in_nc=1):
        super().__init__()
 
        def block(in_f, out_f, stride):
            return [
                nn.Conv2d(in_f, out_f, 3, stride, 1, bias=False),
                nn.BatchNorm2d(out_f),
                nn.LeakyReLU(0.2, inplace=True),
            ]
 
        layers = [nn.Conv2d(in_nc, 64, 3, 1, 1),
                  nn.LeakyReLU(0.2, inplace=True)]
        layers += block(64,  64,  2)
        layers += block(64,  128, 1)
        layers += block(128, 128, 2)
        layers += block(128, 256, 1)
        layers += block(256, 256, 2)
        layers += block(256, 512, 1)
        layers += block(512, 512, 2)
 
        self.features = nn.Sequential(*layers)
        self.classifier = nn.Sequential(
            nn.AdaptiveAvgPool2d(1),
            nn.Flatten(),
            nn.Linear(512, 1024),
            nn.LeakyReLU(0.2, inplace=True),
            nn.Linear(1024, 1),
        )
 
    def forward(self, x):
        return self.classifier(self.features(x))
 
 
# ── VGG Perceptual Loss (grayscale — repeat channel trick) ────
class VGGPerceptualLoss(nn.Module):
    """
    Uses VGG19 conv3_4 features for perceptual loss.
    SAR is grayscale so we expand to 3 channels before VGG.
    """
    def __init__(self):
        super().__init__()
        vgg = models.vgg19(weights=models.VGG19_Weights.DEFAULT)
        # Use features up to conv3_4 (layer index 18)
        self.feature_extractor = nn.Sequential(
            *list(vgg.features.children())[:18]
        ).eval()
        for p in self.feature_extractor.parameters():
            p.requires_grad = False
 
    def forward(self, sr, hr):
        # Expand grayscale → 3-channel (VGG expects RGB)
        sr3 = sr.repeat(1, 3, 1, 1)
        hr3 = hr.repeat(1, 3, 1, 1)
        return nn.functional.mse_loss(
            self.feature_extractor(sr3),
            self.feature_extractor(hr3)
        )
 
 
