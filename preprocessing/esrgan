# STEP 3 — Stream patches → HDF5
# ════════════════════════════════════════════════════════════
def build_hdf5(image_dir, output_path, max_tiles):
    tile_files = sorted([f for f in os.listdir(image_dir)
                         if f.endswith('.png')])
    if len(tile_files) > max_tiles:
        np.random.seed(42)
        tile_files = list(np.random.choice(
            tile_files, max_tiles, replace=False))

    # Count patches first
    total = 0
    for fname in tile_files:
        img  = Image.open(os.path.join(image_dir, fname)).convert('L')
        W_t, H_t = img.size
        W_a = W_t // SCALE * SCALE
        H_a = H_t // SCALE * SCALE
        total += max(0, (H_a - LABEL_SIZE) // STRIDE_P + 1) * \
                 max(0, (W_a - LABEL_SIZE) // STRIDE_P + 1)
    print(f"   Total patches: {total:,}")

    with h5py.File(output_path, 'w') as hf:
        ds_lr = hf.create_dataset('data',
            shape=(total, 1, LABEL_SIZE, LABEL_SIZE),
            dtype=np.float32, compression='gzip',
            compression_opts=1,
            chunks=(256, 1, LABEL_SIZE, LABEL_SIZE))
        ds_hr = hf.create_dataset('label',
            shape=(total, 1, LABEL_SIZE, LABEL_SIZE),
            dtype=np.float32, compression='gzip',
            compression_opts=1,
            chunks=(256, 1, LABEL_SIZE, LABEL_SIZE))

        write_idx = 0
        CHUNK = 512
        lr_buf, hr_buf = [], []

        for fname in tqdm(tile_files, desc=os.path.basename(output_path)):
            img  = Image.open(
                os.path.join(image_dir, fname)).convert('L')
            W_t, H_t = img.size
            W_a = W_t // SCALE * SCALE
            H_a = H_t // SCALE * SCALE
            img = img.resize((W_a, H_a), Image.BICUBIC)

            hr_arr = np.array(img).astype(np.float32) / 255.0
            lr_img = img.resize(
                (W_a//SCALE, H_a//SCALE), Image.BICUBIC)
            lr_img = lr_img.resize((W_a, H_a), Image.BICUBIC)
            lr_arr = np.array(lr_img).astype(np.float32) / 255.0

            for y in range(0, H_a - LABEL_SIZE + 1, STRIDE_P):
                for x in range(0, W_a - LABEL_SIZE + 1, STRIDE_P):
                    hr_buf.append(
                        hr_arr[y:y+LABEL_SIZE,
                               x:x+LABEL_SIZE][np.newaxis])
                    lr_buf.append(
                        lr_arr[y:y+LABEL_SIZE,
                               x:x+LABEL_SIZE][np.newaxis])
                    if len(hr_buf) >= CHUNK:
                        end = write_idx + len(hr_buf)
                        ds_lr[write_idx:end] = np.array(lr_buf)
                        ds_hr[write_idx:end] = np.array(hr_buf)
                        write_idx += len(hr_buf)
                        lr_buf, hr_buf = [], []

            del img, hr_arr, lr_arr, lr_img
            gc.collect()

        if hr_buf:
            end = write_idx + len(hr_buf)
            ds_lr[write_idx:end] = np.array(lr_buf)
            ds_hr[write_idx:end] = np.array(hr_buf)
            write_idx += len(hr_buf)

    size_mb = os.path.getsize(output_path) / 1e6
    print(f" Saved: {output_path}  ({size_mb:.1f} MB)  "
          f"| {write_idx:,} patches")
    return write_idx

